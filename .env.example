# ===========================================================================
# AXVELA Gallery OS — 환경변수 예시 파일
# ===========================================================================
#
# 본 파일은 git에 commit됩니다 (`.env.example`). 실제 값은 `.env.local`에
# 작성하거나 Vercel Dashboard → Project → Settings → Environment Variables에
# 추가하세요. `.env.local`은 `.gitignore`에 의해 git에서 제외됩니다.
#
# ---------------------------------------------------------------------------

# STEP 57 — Vercel Blob (이미지 외부 storage)
#
# Vercel Dashboard → Storage → Create Blob Store → 토큰 자동 발급
# 또는 기존 store에서 BLOB_READ_WRITE_TOKEN 복사
#
# 이 토큰이 부재하면 서버측 API route가 503 응답 → 클라이언트가 자동으로
# LocalPreviewProvider(base64 inline)로 fallback. 사용자 흐름 끊김 0건.
#
# Production / Preview / Development 모두에 동일 토큰 설정 권장.
BLOB_READ_WRITE_TOKEN=

# ===========================================================================
# 향후 추가 환경변수 자리
# ===========================================================================
# 예) STEP 58 Cloudflare R2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# 예) STEP 59 외부 검수사 API:
# CONDITION_INSPECTOR_API_KEY=
